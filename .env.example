# App configuration
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0

# Redis configuration
REDIS_URL=redis://localhost:6379/0

# Cloudflare R2 configuration
# Leave empty during initial local development, but fill in to test actual uploads
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=lynk-transfers

# Limits
MAX_FILES_PER_TRANSFER=10
MAX_INDIVIDUAL_FILE_SIZE=209715200
MAX_TOTAL_TRANSFER_SIZE=524288000
TRANSFER_LIFETIME_SECONDS=1800
RECEIVER_SESSION_LIFETIME_SECONDS=600
UPLOAD_URL_LIFETIME_SECONDS=900
DOWNLOAD_URL_LIFETIME_SECONDS=300

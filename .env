# App configuration
ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0

# Redis configuration
REDIS_URL=redis://localhost:6379/0

# Cloudflare R2 configuration (mock values for local dev/testing)
R2_ACCOUNT_ID=mock_account_id
R2_ACCESS_KEY_ID=mock_access_key
R2_SECRET_ACCESS_KEY=mock_secret_key
R2_BUCKET_NAME=lynk-transfers

# Limits
MAX_FILES_PER_TRANSFER=10
MAX_INDIVIDUAL_FILE_SIZE=52428800
MAX_TOTAL_TRANSFER_SIZE=524288000
TRANSFER_LIFETIME_SECONDS=1800
RECEIVER_SESSION_LIFETIME_SECONDS=600
UPLOAD_URL_LIFETIME_SECONDS=900
DOWNLOAD_URL_LIFETIME_SECONDS=300
